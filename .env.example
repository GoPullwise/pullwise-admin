VITE_APP_URL=http://localhost:5174
VITE_API_BASE_URL=http://localhost:8080

# Cloudflare Workers production build values, usually in .env.production:
# VITE_APP_URL=https://pullwise-admin.danuberiverferryman.workers.dev
# VITE_API_BASE_URL=https://api.your-domain.com
#
# Optional same-origin API proxy upstream, configured in wrangler.jsonc or a Worker secret:
# Use this only when VITE_API_BASE_URL=/api.
# PULLWISE_API_ORIGIN=https://api.your-domain.com
#
# GitHub OAuth secrets and admin email/user-id allowlists remain on pullwise-server.
